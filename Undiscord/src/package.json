{
  "name": "undiscord",
  "version": "1.0.0",
  "description": "A selfbot that cleans/deletes your own messages in a Discord channel with filters.",
  "main": "main.js",
  "bin": "main.js",
  "scripts": {
    "build": "caxa --input . --output cleaner.exe -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/main.js\""
  },
  "dependencies": {
    "debug": "^4.4.3",
    "discord.js-selfbot-v13": "^3.7.1"
  },
  "devDependencies": {
    "caxa": "latest"
  },
  "overrides": {
    "sqlite": "4.2.1",
    "undici": "5.28.4"
  }
}