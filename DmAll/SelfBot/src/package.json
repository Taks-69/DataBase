{
  "name": "dmall-selfbot",
  "version": "1.0.0",
  "description": "A selfbot that sends DMs to all friends/users.",
  "main": "self.js",
  "bin": "self.js",
  "scripts": {
    "build": "caxa --input . --output dmall-selfbot.exe -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/self.js\""
  },
  "dependencies": {
    "debug": "^4.4.3",
    "discord.js-selfbot-v13": "^3.7.1"
  },
  "devDependencies": {
    "caxa": "latest"
  },
  "overrides": {
    "sqlite": "4.2.1",
    "undici": "5.28.4"
  }
}