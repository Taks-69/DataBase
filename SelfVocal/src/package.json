{
  "name": "self-vocal",
  "version": "1.0.0",
  "description": "Discord selfbot voice joiner to stay connected in a vocal channel.",
  "main": "vocal.js",
  "private": true,
  "scripts": {
    "start": "node vocal.js",
    "build": "caxa --input . --output .exe -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/vocal.js\""
  },
  "dependencies": {
    "debug": "^4.4.3",
    "discord.js-selfbot-v13": "^3.7.1"
  },
  "devDependencies": {
    "caxa": "latest"
  },
  "overrides": {
    "sqlite": "4.2.1",
    "undici": "5.28.4"
  }
}